{
  "_comment": "Resilience Configuration \u00e2\u20ac\u201d System Hardening V3",
  "_version": "3.0",
  "local_queue_buffer": {
    "enabled": true,
    "pending_sync_dir": "pending_sync",
    "latency_threshold_ms": 3000,
    "max_queue_size_mb": 50,
    "retry_interval_seconds": 60,
    "max_retries": 10,
    "flush_on_recovery": true
  },
  "cloud_health": {
    "watchdog_url": "https://humanresource.app.n8n.cloud/webhook/system-watchdog-ping",
    "timeout_ms": 5000,
    "check_interval_seconds": 900,
    "consecutive_failures_for_offline": 2
  },
  "circuit_breaker_defaults": {
    "failure_threshold": 3,
    "cooldown_seconds": 120,
    "success_threshold": 2
  },
  "offline_mode": {
    "auto_engage": true,
    "notification_topic": "antigravity-security",
    "log_to_error_aggregator": true
  }
}