# ═══════════════════════════════════════════════════════
#  Meta App Factory — Environment Template
#  This file SYNCS via Google Drive. It is NOT a secret.
#  Copy to .env and fill in your API keys.
# ═══════════════════════════════════════════════════════

# ── LLM / AI ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── LangChain Observability ───────────────────────────
LANGCHAIN_API_KEY=your_langchain_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=Meta_App_Factory

# ── Supabase (Memory) ────────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# ── Ngrok (Tunneling) ────────────────────────────────
NGROK_AUTH_TOKEN=your_ngrok_token_here

# ── N8N (Workflow Automation) ─────────────────────────
N8N_API_KEY=your_n8n_api_key_here

# ═══════════════════════════════════════════════════════
#  MACHINE-LOCAL (auto-set by bootstrap, do NOT edit)
# ═══════════════════════════════════════════════════════
# ALPHA_RUNTIME_DIR is auto-detected at launch time.
# Do NOT set it here — the launch scripts handle it.
