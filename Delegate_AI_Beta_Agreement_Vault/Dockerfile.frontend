# ── Delegate AI Beta-Agreement Vault — Frontend Dockerfile ──
FROM node:20-alpine AS build

WORKDIR /app
COPY vault_ui/package.json vault_ui/package-lock.json* ./
RUN npm install
COPY vault_ui/ ./
RUN npm run build

# Serve with lightweight nginx
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY vault_ui/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
