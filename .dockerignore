# =========================================================
# META APP FACTORY CORE — DOCKER IGNORE
# =========================================================
# Prevents massive build context bloat by blocking child apps
# and local runtime data from the global API daemon.

# Block all child macro-applications
Alpha_V2_Genesis/
Resonance/
Resonance2/
Resonance3/
Resonance4/
Sentinel_Bridge/
CMO_Agent/
CFO_Agent/
CIO_Agent/
CLO_Agent/
CPO_Agent/
Command_Center/
Venture_Architect_Agent/
Adv_Autonomous_Agent/
HR_N8N_Bridge/

# Block persistent runtime data & state
.Gemini_state/
scratch/
tmp/
*.json
!registry.json
!commands.json
!resilience_config.json
!V3_MAP.json
!antigravity.brand.json

# Block local documentation/reports
*.html
*.pdf

# Python caching
__pycache__/
*.pyc

# Local Git & env
.git/
.env
