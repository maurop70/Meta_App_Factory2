[Unit]
Description=ERP Maintenance Backend Microservice (Port 8000)
After=network.target

[Service]
User=root
WorkingDirectory=/opt/erp/backend
Environment="PATH=/opt/erp/backend/venv/bin"
ExecStart=/opt/erp/backend/venv/bin/uvicorn maintenance_backend:app --host 127.0.0.1 --port 8000 --workers 4

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
