# PulseBoard - Frontend Container
# Generated by Meta App Factory
FROM node:20-alpine AS build

WORKDIR /app

# Dependencies first for Docker layer caching
COPY resonance_ui/package*.json ./
RUN npm ci

# Build
COPY resonance_ui/ .
RUN npm run build

# Production serve
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
