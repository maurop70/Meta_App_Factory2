function setupDashboard() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  ss.rename(CONFIG.sheetName);
  
  // Create all tabs
  buildCommandCenter(ss);
  buildFiscalOversight(ss);
  buildProjectIndex(ss);
  buildBoardroomFeed(ss);
  buildSystemHealth(ss);
  buildDelegateAI(ss);
  
  // Remove default Sheet1 if it still exists
  const defaultSheet = ss.getSheetByName("Sheet1");
  if (defaultSheet && ss.getSheets().length > 1) {
    ss.deleteSheet(defaultSheet);
  }
  
  // Set Command Center as active
  ss.setActiveSheet(ss.getSheetByName("⚡ Command Center"));
  
  SpreadsheetApp.getUi().alert(
    "✅ Dashboard Deployed!\n\n" +
    "Tabs created:\n" +
