      sheet.getRange(r, 2).setBackground(CONFIG.colors.activeBg).setFontColor(CONFIG.colors.activeText);
    } else if (row[1].includes("⏳")) {
      sheet.getRange(r, 2).setBackground(CONFIG.colors.placeholderBg).setFontColor(CONFIG.colors.placeholderText);
    }
  });
  
  // ── Formatting ──
  sheet.setColumnWidth(1, 200);
  sheet.setColumnWidth(2, 200);
  sheet.setColumnWidth(3, 140);
  sheet.setColumnWidth(4, 140);
  sheet.setColumnWidth(5, 140);
  sheet.setColumnWidth(6, 140);
  sheet.setColumnWidth(7, 120);
  sheet.setColumnWidth(8, 200);
  sheet.setFrozenRows(4);
}

