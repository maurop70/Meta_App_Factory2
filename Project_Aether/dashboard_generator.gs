//  TAB 6: PRODUCT — DELEGATE AI Tracker
// ══════════════════════════════════════════════════

function buildDelegateAI(ss) {
  // Remove old tab name if it exists
  const oldSheet = ss.getSheetByName("🎯 Mission Genesis");
  if (oldSheet) ss.deleteSheet(oldSheet);
  
  let sheet = ss.getSheetByName("🚀 Product: Delegate_AI");
  if (!sheet) sheet = ss.insertSheet("🚀 Product: Delegate_AI");
  sheet.clear();
  sheet.setTabColor("#e91e63");
  
  // ── Title ──
  sheet.getRange("A1:H1").merge().setValue("🚀 PRODUCT: DELEGATE AI — PILOT TRACKER")
    .setBackground(CONFIG.colors.headerBg).setFontColor(CONFIG.colors.headerText)
    .setFontSize(16).setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange("A2:H2").merge()
    .setValue("Product Lead: CTO | Compliance: CLEARED | Budget: APPROVED | " + new Date().toISOString())
    .setBackground(CONFIG.colors.accentBg).setFontColor(CONFIG.colors.accentText)
    .setFontSize(9).setHorizontalAlignment("center");
  
  // ── Opportunity Matrix ──
  sheet.getRange("A4:H4").setValues([["Rank", "Friction Zone", "Sector", "Severity", "Market Size", "Build Complexity", "Critic Score", "Status"]])
    .setBackground(CONFIG.colors.sectionHeader).setFontColor(CONFIG.colors.sectionText)
    .setFontWeight("bold");
  
  const opportunities = [
    ["1", "Legal Task Delegation", "Legal", "🔴 CRITICAL", "440K+ firms", "LOW", "8.4/10", "✅ PRIMARY TARGET"],
    ["2", "CI/CD Pipeline Triage", "Software", "🔴 CRITICAL", "$40B market", "MEDIUM", "8.1/10", "✅ SECONDARY TARGET"],
    ["3", "Contract Analysis", "Legal", "🔴 CRITICAL", "$15B market", "HIGH", "6.2/10", "❌ Deferred (complexity)"],
    ["4", "Integration Watch", "Software", "🟡 HIGH", "$30B market", "LOW", "7.0/10", "🟡 Promising, deferred"],
    ["5", "PR Triage", "Software", "🟡 HIGH", "27M devs", "MEDIUM", "5.8/10", "❌ Saturated market"],
    ["6", "Compliance Watch", "Legal", "🟡 HIGH", "$8B market", "MEDIUM", "6.5/10", "🟡 Niche, deferred"],
    ["7", "Doc Sync", "Software", "🟡 HIGH", "$12B market", "LOW", "5.5/10", "❌ Feature, not product"],
  ];
  
  opportunities.forEach((row, i) => {
    const r = 5 + i;
    sheet.getRange(r, 1, 1, 8).setValues([row]);
    sheet.getRange(r, 2).setFontWeight("bold");
    
    if (row[7].includes("PRIMARY")) {
      sheet.getRange(r, 8).setBackground(CONFIG.colors.activeBg).setFontColor(CONFIG.colors.activeText);
      sheet.getRange(r, 1, 1, 8).setBackground("#0a2e0a");
    } else if (row[7].includes("SECONDARY")) {
      sheet.getRange(r, 8).setBackground(CONFIG.colors.activeBg).setFontColor(CONFIG.colors.activeText);
    } else if (row[7].includes("Deferred") || row[7].includes("Saturated") || row[7].includes("Feature")) {
      sheet.getRange(r, 8).setBackground(CONFIG.colors.criticalBg).setFontColor(CONFIG.colors.criticalText);
    } else {
      sheet.getRange(r, 8).setBackground(CONFIG.colors.placeholderBg).setFontColor(CONFIG.colors.placeholderText);
    }
  });
  
  // ── Pilot Agent: Delegate AI ──
  const pilotRow = 5 + opportunities.length + 2;
  sheet.getRange(pilotRow, 1, 1, 6).merge().setValue("🚀 PILOT AGENT: DELEGATE AI — Legal Task Delegation")
    .setBackground("#1b5e20").setFontColor("#ffffff")
    .setFontSize(14).setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange(pilotRow + 1, 1, 1, 4).setValues([["Metric", "Conservative", "Target", "Optimistic"]])
    .setBackground(CONFIG.colors.accentBg).setFontColor(CONFIG.colors.accentText).setFontWeight("bold");
  
  const projections = [
    ["Beta Firms", "5", "15", "30"],
    ["Total Seats", "25", "75", "200"],
    ["Price/Seat/Mo", "$49", "$69", "$99"],
    ["Monthly Recurring Revenue", "$1,225", "$5,175", "$19,800"],
    ["Annual Recurring Revenue", "$14,700", "$62,100", "$237,600"],
    ["Pilot Investment", "$1,447", "—", "$2,725"],
    ["Break-Even", "Month 6", "Month 4", "Month 4"],
    ["Year 1 ROI", "915%", "2,178%", "8,617%"],
  ];
  
  projections.forEach((row, i) => {
    const r = pilotRow + 2 + i;
    sheet.getRange(r, 1, 1, 4).setValues([row]);
    sheet.getRange(r, 1).setFontWeight("bold");
    if (row[0] === "Annual Recurring Revenue") {
      sheet.getRange(r, 1, 1, 4).setFontSize(12).setFontWeight("bold");
      sheet.getRange(r, 3).setFontColor(CONFIG.colors.activeText);
    }
    if (row[0] === "Year 1 ROI") {
      sheet.getRange(r, 1, 1, 4).setBackground(CONFIG.colors.activeBg).setFontColor(CONFIG.colors.activeText).setFontWeight("bold");
    }
  });
  
  // ── Pipeline Status ──
  const pipeRow = pilotRow + 2 + projections.length + 2;
  sheet.getRange(pipeRow, 1, 1, 4).merge().setValue("📋 PILOT PIPELINE STATUS")
    .setBackground(CONFIG.colors.sectionHeader).setFontColor(CONFIG.colors.sectionText)
    .setFontWeight("bold").setHorizontalAlignment("center");
  
  const pipeline = [
    ["Deep Crawler Scan", "✅ Complete", "Deep Crawler", "7 friction zones mapped"],
    ["Critic Validation", "✅ Complete", "The Critic", "L1 + S1 approved"],
    ["CFO Budget", "✅ Approved", "CFO", "$1.4K-$2.7K allocated"],
    ["CTO Architecture Brief", "⏳ Pending", "CTO", "Due within 48 hours"],
    ["Compliance Data Review", "⏳ Pending", "Compliance Officer", "Attorney-client privilege check"],
    ["Pilot Build", "🔲 Not Started", "CTO + Data Architect", "Awaiting architecture brief"],
    ["Beta Firm Outreach", "🔲 Not Started", "CEO + CMO", "5-10 firms targeted"],
  ];
  
  sheet.getRange(pipeRow + 1, 1, 1, 4).setValues([["Phase", "Status", "Owner", "Notes"]])
    .setBackground(CONFIG.colors.accentBg).setFontColor(CONFIG.colors.accentText).setFontWeight("bold");
  
  pipeline.forEach((row, i) => {
