    "Run autoRefresh() or set a time trigger for auto-updates."
  );
}

// ══════════════════════════════════════════════════
//  TAB 1: AGENT COMMAND CENTER
// ══════════════════════════════════════════════════

function buildCommandCenter(ss) {
  let sheet = ss.getSheetByName("⚡ Command Center");
  if (!sheet) sheet = ss.insertSheet("⚡ Command Center");
  sheet.clear();
  sheet.setTabColor("#4caf50");
  
  // ── Title Block ──
  sheet.getRange("A1:H1").merge().setValue("⚡ PROJECT AETHER — AGENT COMMAND CENTER")
    .setBackground(CONFIG.colors.headerBg).setFontColor(CONFIG.colors.headerText)
    .setFontSize(16).setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange("A2:H2").merge()
    .setValue("Last Refresh: " + new Date().toISOString() + " | v" + CONFIG.version)
    .setBackground(CONFIG.colors.accentBg).setFontColor(CONFIG.colors.accentText)
    .setFontSize(9).setHorizontalAlignment("center");
  
  // ── Summary KPIs ──
  const activeCount = AGENT_REGISTRY.filter(a => a.status === "ACTIVE").length;
  const placeholderCount = AGENT_REGISTRY.filter(a => a.status === "PLACEHOLDER").length;
  
  sheet.getRange("A4").setValue("ACTIVE AGENTS").setFontWeight("bold");
  sheet.getRange("B4").setValue(activeCount).setFontSize(20).setFontWeight("bold")
    .setFontColor(CONFIG.colors.activeText).setBackground(CONFIG.colors.activeBg)
    .setHorizontalAlignment("center");
  
  sheet.getRange("C4").setValue("PLACEHOLDER").setFontWeight("bold");
  sheet.getRange("D4").setValue(placeholderCount).setFontSize(20).setFontWeight("bold")
    .setFontColor(CONFIG.colors.placeholderText).setBackground(CONFIG.colors.placeholderBg)
    .setHorizontalAlignment("center");
    
  sheet.getRange("E4").setValue("TOTAL ROSTER").setFontWeight("bold");
  sheet.getRange("F4").setValue(AGENT_REGISTRY.length).setFontSize(20).setFontWeight("bold")
    .setFontColor("#ffffff").setBackground(CONFIG.colors.sectionHeader)
    .setHorizontalAlignment("center");
  
  // ── Agent Table ──
  const headers = ["Agent", "Role", "Division", "Status", "Model", "Reports To", "Config Version", "Isolation"];
  const headerRange = sheet.getRange(6, 1, 1, headers.length);
  headerRange.setValues([headers])
    .setBackground(CONFIG.colors.sectionHeader).setFontColor(CONFIG.colors.sectionText)
    .setFontWeight("bold").setHorizontalAlignment("center");
  
  AGENT_REGISTRY.forEach((agent, i) => {
    const row = 7 + i;
    const statusEmoji = agent.status === "ACTIVE" ? "✅" : "🟡";
    sheet.getRange(row, 1).setValue(agent.name).setFontWeight("bold");
    sheet.getRange(row, 2).setValue(agent.role);
    sheet.getRange(row, 3).setValue(agent.division);
    sheet.getRange(row, 4).setValue(statusEmoji + " " + agent.status)
      .setBackground(agent.status === "ACTIVE" ? CONFIG.colors.activeBg : CONFIG.colors.placeholderBg)
      .setFontColor(agent.status === "ACTIVE" ? CONFIG.colors.activeText : CONFIG.colors.placeholderText);
    sheet.getRange(row, 5).setValue(agent.model);
    sheet.getRange(row, 6).setValue(agent.reports_to);
    sheet.getRange(row, 7).setValue(agent.status === "ACTIVE" ? "v2.0.0" : "v1.1.0");
    sheet.getRange(row, 8).setValue("✅ Aether Boundary");
  });
  
  // ── Division Summary ──
  const divRow = 7 + AGENT_REGISTRY.length + 2;
  sheet.getRange(divRow, 1, 1, 4).merge().setValue("DIVISION BREAKDOWN")
    .setBackground(CONFIG.colors.sectionHeader).setFontColor(CONFIG.colors.sectionText)
    .setFontWeight("bold").setHorizontalAlignment("center");
  
  const divisions = ["C-Suite_Core", "Intelligence_Ops", "Systems_Audit", "Creative_Studio"];
  divisions.forEach((div, i) => {
    const agents = AGENT_REGISTRY.filter(a => a.division === div);
    const active = agents.filter(a => a.status === "ACTIVE").length;
    const r = divRow + 1 + i;
    sheet.getRange(r, 1).setValue(div).setFontWeight("bold");
    sheet.getRange(r, 2).setValue(active + "/" + agents.length + " Active");
    sheet.getRange(r, 3).setValue(agents.map(a => a.name).join(", "));
  });
  
  // ── Formatting ──
  sheet.setColumnWidth(1, 160);
  sheet.setColumnWidth(2, 280);
  sheet.setColumnWidth(3, 150);
  sheet.setColumnWidth(4, 140);
  sheet.setColumnWidth(5, 160);
  sheet.setColumnWidth(6, 120);
  sheet.setColumnWidth(7, 120);
  sheet.setColumnWidth(8, 140);
  sheet.setFrozenRows(6);
}

