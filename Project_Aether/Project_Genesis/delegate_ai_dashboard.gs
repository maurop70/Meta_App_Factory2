const DAI_CONFIG = {
  sheetName: "Delegate AI — Pilot Dashboard",
  version: "1.1.0",
  colors: {
    headerBg: "#1b5e20",
    headerText: "#e8f5e9",
    activeBg: "#0d4d0d",
    activeText: "#4cff4c",
    pendingBg: "#4d4d00",
    pendingText: "#ffff4c",
    blockedBg: "#4d0d0d",
    blockedText: "#ff4c4c",
    accentBg: "#1a1a2e",
    accentText: "#c8d6e5",
    sectionHeader: "#0a3d62",
    sectionText: "#ffffff",
  }
};

// ══════════════════════════════════════════════════
//  MAIN SETUP
// ══════════════════════════════════════════════════

function setupDelegateAIDashboard() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  ss.rename(DAI_CONFIG.sheetName);
  
  buildPilotOverview(ss);
  buildBuildTracker(ss);
  buildBetaFirmTracker(ss);
  buildComplianceStatus(ss);
  buildFinancials(ss);
  
  const defaultSheet = ss.getSheetByName("Sheet1");
  if (defaultSheet && ss.getSheets().length > 1) {
    ss.deleteSheet(defaultSheet);
  }
  
  ss.setActiveSheet(ss.getSheetByName("📊 Pilot Overview"));
  
  SpreadsheetApp.getUi().alert(
    "✅ Delegate AI Dashboard Deployed!\n\n" +
    "• 📊 Pilot Overview — KPIs & status\n" +
    "• 🔨 Build Tracker — 10-day sprint\n" +
    "• 🏢 Beta Firms — Outreach pipeline\n" +
    "• 🛡️ Compliance — Privacy shield status\n" +
    "• 💰 Financials — Budget vs. actuals"
  );
}

// ══════════════════════════════════════════════════
//  TAB 1: PILOT OVERVIEW
// ══════════════════════════════════════════════════

function buildPilotOverview(ss) {
  let sheet = ss.getSheetByName("📊 Pilot Overview");
  if (!sheet) sheet = ss.insertSheet("📊 Pilot Overview");
  sheet.clear();
  sheet.setTabColor("#4caf50");
  
  sheet.getRange("A1:F1").merge().setValue("📊 DELEGATE AI — PILOT OVERVIEW")
    .setBackground(DAI_CONFIG.colors.headerBg).setFontColor(DAI_CONFIG.colors.headerText)
    .setFontSize(16).setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange("A2:F2").merge()
    .setValue("Product: Legal Task Delegation SaaS | v" + DAI_CONFIG.version + " | " + new Date().toISOString())
    .setBackground(DAI_CONFIG.colors.accentBg).setFontColor(DAI_CONFIG.colors.accentText)
    .setFontSize(9).setHorizontalAlignment("center");
  
  // KPIs
  const kpis = [
    ["Build Progress", "100%", "All 5 phases complete", "CTO"],
    ["Beta Firms Signed", "0 / 10", "Outreach pending", "CEO + CMO"],
    ["Compliance Status", "✅ CLEARED", "Privacy Shield active", "Compliance Officer"],
    ["Budget Spent", "$0 / $2,725", "Approved, not yet deployed", "CFO"],
    ["Days to MVP", "0", "✅ MVP Complete — 2026-03-08", "CTO"],
    ["Pilot Duration", "90 days", "Ready to launch", "CEO"],
  ];
  
  sheet.getRange("A4:D4").setValues([["Metric", "Value", "Detail", "Owner"]])
    .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText)
    .setFontWeight("bold");
  
  kpis.forEach((row, i) => {
    sheet.getRange(5 + i, 1, 1, 4).setValues([row]);
    sheet.getRange(5 + i, 1).setFontWeight("bold");
    sheet.getRange(5 + i, 2).setFontSize(14).setFontWeight("bold").setHorizontalAlignment("center");
  });
  
  // Key Documents
  const docRow = 5 + kpis.length + 2;
  sheet.getRange(docRow, 1, 1, 3).merge().setValue("📁 KEY DOCUMENTS (Project_Genesis/Boardroom/)")
    .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText)
    .setFontWeight("bold").setHorizontalAlignment("center");
  
  const docs = [
    ["DELEGATE_AI_TECH_STACK.md", "CTO", "Architecture + DB schema + API endpoints"],
    ["PRIVACY_SHIELD_REPORT.md", "Compliance Officer", "5-layer privilege safeguards"],
    ["CFO_PILOT_AGENT_BUDGET.md", "CFO", "$1.4K-$2.7K pilot budget"],
    ["DEEP_CRAWLER_GENESIS_SCAN.md", "Deep Crawler", "7 friction zones, L1 = primary"],
    ["CRITIC_GENESIS_VALIDATION.md", "The Critic", "L1 + S1 approved, 5 deferred"],
    ["BETA_FIRM_TARGET_LIST.md", "CEO + CMO", "10 firm segments, 3-phase outreach"],
    ["pitch_deck_generator.gs", "Creative Studio", "10-slide Google Slides pitch deck"],
    ["DELEGATE_AI_BROCHURE.md", "Graphic Designer", "2-page product brochure"],
    ["VISUAL_AUDIT_REPORT.md", "The Critic", "Visual audit: deck 8.6, brochure 9.0"],
    ["COMPLIANCE_CLEARANCE_v2.md", "Compliance Officer", "Universal clearance — all remediations confirmed"],
  ];
  
  sheet.getRange(docRow + 1, 1, 1, 3).setValues([["Document", "Author", "Summary"]])
    .setBackground(DAI_CONFIG.colors.accentBg).setFontColor(DAI_CONFIG.colors.accentText).setFontWeight("bold");
  
  docs.forEach((row, i) => {
    sheet.getRange(docRow + 2 + i, 1, 1, 3).setValues([row]);
    sheet.getRange(docRow + 2 + i, 1).setFontWeight("bold");
  });
  
  sheet.setColumnWidth(1, 280);
  sheet.setColumnWidth(2, 180);
  sheet.setColumnWidth(3, 300);
  sheet.setColumnWidth(4, 160);
  sheet.setFrozenRows(4);
}

// ══════════════════════════════════════════════════
//  TAB 2: BUILD TRACKER (10-Day Sprint)
// ══════════════════════════════════════════════════

function buildBuildTracker(ss) {
  let sheet = ss.getSheetByName("🔨 Build Tracker");
  if (!sheet) sheet = ss.insertSheet("🔨 Build Tracker");
  sheet.clear();
  sheet.setTabColor("#ff9800");
  
  sheet.getRange("A1:F1").merge().setValue("🔨 BUILD TRACKER — 10-DAY MVP SPRINT")
    .setBackground(DAI_CONFIG.colors.headerBg).setFontColor(DAI_CONFIG.colors.headerText)
    .setFontSize(16).setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange("A2:F2").merge()
    .setValue("Owner: CTO | Source: DELEGATE_AI_TECH_STACK.md | " + new Date().toISOString())
    .setBackground(DAI_CONFIG.colors.accentBg).setFontColor(DAI_CONFIG.colors.accentText)
    .setFontSize(9).setHorizontalAlignment("center");
  
  sheet.getRange("A4:F4").setValues([["Phase", "Duration", "Deliverable", "Status", "Owner", "Blockers"]])
    .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText)
    .setFontWeight("bold");
  
  const phases = [
    ["Phase 1: Schema + API", "Day 1-2", "Supabase tables, FastAPI endpoints", "✅ Complete", "CTO", "4 tables + seed, httpx REST client, 11/11 tests"],
    ["Phase 2: Runtime Extension", "Day 3-4", "Legal intent patterns, delegation routing", "✅ Complete", "CTO", "delegation_router.py + Boardroom logging"],
    ["Phase 3: n8n Workflow", "Day 5", "legal-delegation-router workflow", "✅ Complete", "CTO", "6-node n8n workflow with escalation"],
    ["Phase 4: Frontend Shell", "Day 6-8", "Task board UI + delegation form", "✅ Complete", "CTO", "Dark mode SPA at localhost:8002/app"],
    ["Phase 5: Integration Test", "Day 9-10", "End-to-end flow with test firm", "✅ Complete", "CTO + Compliance", "14 tasks in Supabase, full routing verified"],
    ["Phase 6: Stress & Security Audit", "Day 10", "API Load Testing + RLS Cross-Tenant Validation", "✅ Complete", "CTO + Compliance Officer", "11/11 endpoints verified, Supabase RLS active"],
  ];
  
  phases.forEach((row, i) => {
    const r = 5 + i;
    sheet.getRange(r, 1, 1, 6).setValues([row]);
    sheet.getRange(r, 1).setFontWeight("bold");
  });
  
  // Tech Stack Summary
  const techRow = 5 + phases.length + 2;
  sheet.getRange(techRow, 1, 1, 3).merge().setValue("🧱 TECH STACK")
    .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText)
    .setFontWeight("bold").setHorizontalAlignment("center");
  
  const stack = [
