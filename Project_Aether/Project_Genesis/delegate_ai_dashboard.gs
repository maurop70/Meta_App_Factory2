function buildComplianceStatus(ss) {
  let sheet = ss.getSheetByName("🛡️ Compliance");
  if (!sheet) sheet = ss.insertSheet("🛡️ Compliance");
  sheet.clear();
  sheet.setTabColor("#9c27b0");
  
  sheet.getRange("A1:D1").merge().setValue("🛡️ PRIVACY SHIELD — COMPLIANCE STATUS")
    .setBackground(DAI_CONFIG.colors.headerBg).setFontColor(DAI_CONFIG.colors.headerText)
    .setFontSize(16).setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange("A2:D2").merge()
    .setValue("Source: PRIVACY_SHIELD_REPORT.md | Audit: PRIVACY-SHIELD-001 | " + new Date().toISOString())
    .setBackground(DAI_CONFIG.colors.accentBg).setFontColor(DAI_CONFIG.colors.accentText)
    .setFontSize(9).setHorizontalAlignment("center");
  
  sheet.getRange("A4:D4").setValues([["#", "Requirement", "Status", "Owner"]])
    .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText)
    .setFontWeight("bold");
  
  const checks = [
    ["1", "ABA Model Rule 1.6 — Confidentiality", "✅ Compliant", "Compliance Officer"],
    ["2", "Data minimization (sanitize_for_ai)", "✅ Designed", "CTO"],
    ["3", "Encryption at rest (Fernet AES-128)", "✅ Active", "Compliance Vault"],
    ["4", "Encryption in transit (TLS 1.3)", "✅ Default", "Infrastructure"],
    ["5", "Firm-level data isolation (RLS)", "✅ Designed", "Data Architect"],
    ["6", "Audit trail for privileged access", "✅ Active", "Compliance Vault"],
    ["7", "Confidential task access control", "✅ Designed", "CTO"],
    ["8", "Retention + auto-deletion policy", "✅ Defined", "Compliance Officer"],
    ["9", "AI model data usage policy", "✅ Verified", "Compliance Officer"],
    ["10", "Human-in-the-loop enforcement", "✅ Designed", "CTO"],
    ["11", "Key rotation (quarterly)", "⏳ P1", "CTO"],
    ["12", "SOC 2 Type II audit", "🔲 Post-pilot", "Future"],
  ];
  
  checks.forEach((row, i) => {
    const r = 5 + i;
    sheet.getRange(r, 1, 1, 4).setValues([row]);
    if (row[2].includes("✅")) {
      sheet.getRange(r, 3).setBackground(DAI_CONFIG.colors.activeBg).setFontColor(DAI_CONFIG.colors.activeText);
    } else if (row[2].includes("⏳")) {
      sheet.getRange(r, 3).setBackground(DAI_CONFIG.colors.pendingBg).setFontColor(DAI_CONFIG.colors.pendingText);
    }
  });
  
  sheet.setColumnWidth(1, 40);
  sheet.setColumnWidth(2, 320);
  sheet.setColumnWidth(3, 160);
  sheet.setColumnWidth(4, 180);
  sheet.setFrozenRows(4);
}

// ══════════════════════════════════════════════════
//  TAB 5: FINANCIALS
// ══════════════════════════════════════════════════

function buildFinancials(ss) {
  let sheet = ss.getSheetByName("💰 Financials");
  if (!sheet) sheet = ss.insertSheet("💰 Financials");
  sheet.clear();
  sheet.setTabColor("#ff9800");
  
  sheet.getRange("A1:E1").merge().setValue("💰 FINANCIALS — BUDGET vs. ACTUALS")
    .setBackground(DAI_CONFIG.colors.headerBg).setFontColor(DAI_CONFIG.colors.headerText)
    .setFontSize(16).setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange("A2:E2").merge()
    .setValue("Source: CFO_PILOT_AGENT_BUDGET.md | " + new Date().toISOString())
    .setBackground(DAI_CONFIG.colors.accentBg).setFontColor(DAI_CONFIG.colors.accentText)
    .setFontSize(9).setHorizontalAlignment("center");
  
  sheet.getRange("A4:E4").setValues([["Category", "Budgeted", "Actual", "Remaining", "Status"]])
    .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText)
    .setFontWeight("bold");
  
  const budget = [
    ["UI/UX Contractor", "$500-1,000", "$0", "$500-1,000", "Not Started"],
    ["Cloud Infrastructure (90-day)", "$60", "$0", "$60", "Not Started"],
    ["Domain Registration", "$12-15", "$0", "$12-15", "Not Started"],
    ["n8n Cloud Pro (3 months)", "$60", "$20", "$40", "Month 1 active"],
    ["Claude API Usage", "$15-75", "$0", "$15-75", "Not Started"],
    ["JD Supra Placement", "$500-1,000", "$0", "$500-1,000", "Pending CMO"],
    ["LinkedIn Ads", "$300-500", "$0", "$300-500", "Pending CMO"],
    ["TOTAL", "$1,447-2,725", "$20", "$1,427-2,705", ""],
  ];
  
  budget.forEach((row, i) => {
    const r = 5 + i;
    sheet.getRange(r, 1, 1, 5).setValues([row]);
    sheet.getRange(r, 1).setFontWeight("bold");
    if (row[0] === "TOTAL") {
      sheet.getRange(r, 1, 1, 5).setFontWeight("bold").setFontSize(12)
        .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText);
    }
  });
  
  // Revenue Projections
  const revRow = 5 + budget.length + 2;
  sheet.getRange(revRow, 1, 1, 4).merge().setValue("📈 REVENUE PROJECTIONS (Post-Pilot)")
    .setBackground(DAI_CONFIG.colors.sectionHeader).setFontColor(DAI_CONFIG.colors.sectionText)
    .setFontWeight("bold").setHorizontalAlignment("center");
  
  sheet.getRange(revRow + 1, 1, 1, 4).setValues([["Scenario", "MRR", "ARR", "ROI"]])
    .setBackground(DAI_CONFIG.colors.accentBg).setFontColor(DAI_CONFIG.colors.accentText).setFontWeight("bold");
  
  const rev = [
    ["Conservative (5 firms, $49/seat)", "$1,225", "$14,700", "915%"],
    ["Target (15 firms, $69/seat)", "$5,175", "$62,100", "2,178%"],
    ["Optimistic (30 firms, $99/seat)", "$19,800", "$237,600", "8,617%"],
  ];
  
  rev.forEach((row, i) => {
    sheet.getRange(revRow + 2 + i, 1, 1, 4).setValues([row]);
    if (row[0].includes("Target")) {
      sheet.getRange(revRow + 2 + i, 1, 1, 4).setFontWeight("bold");
      sheet.getRange(revRow + 2 + i, 3).setFontColor(DAI_CONFIG.colors.activeText).setFontSize(14);
    }
  });
  
  sheet.setColumnWidth(1, 280);
  sheet.setColumnWidth(2, 140);
  sheet.setColumnWidth(3, 140);
  sheet.setColumnWidth(4, 140);
  sheet.setColumnWidth(5, 140);
  sheet.setFrozenRows(4);
}

// ══════════════════════════════════════════════════
//  UTILITIES
// ══════════════════════════════════════════════════

function refreshDelegateAI() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  buildPilotOverview(ss);
  buildBuildTracker(ss);
  buildBetaFirmTracker(ss);
  buildComplianceStatus(ss);
  buildFinancials(ss);
}

function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu("🚀 Delegate AI")
    .addItem("Refresh All Tabs", "refreshDelegateAI")
    .addItem("Rebuild Dashboard", "setupDelegateAIDashboard")
    .addToUi();
}
